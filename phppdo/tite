<?php
// 1. Process Logic First (Deletes, Updates, Inserts)
require 'config.php';
require 'insert.php';
require 'update.php';
require 'delete.php';

// 2. Fetch the data via the JOIN inside select.php
// This must come BEFORE the edit logic so $users is available.
require 'select.php'; 

// CHECK IF EDIT MODE
$editUser = null;
if (isset($_GET['edit'])) {
    $target_id = $_GET['edit'];
    
    // Instead of a new SQL query, we search the $users list 
    // This list already contains Name, Email, Product, and Amount.
    foreach ($users as $u) {
        if ($u['users_id'] == $target_id) {
            $editUser = $u;
            break;
        }
    }
}
?>

<h2>Simple PDO CRUD</h2>

<h3><?= $editUser ? 'Update User' : 'Add User' ?></h3>

<form method="POST">
  <?php if (!empty($editUser)): ?>
    <input type="hidden" name="users_id" value="<?= $editUser['users_id'] ?>">
  <?php endif; ?>

  <label>Name:</label>
  <input type="text" name="name" value="<?= $editUser ? $editUser['name'] : '' ?>" required><br>

  <label>Email:</label>
  <input type="email" name="email" value="<?= $editUser ? $editUser['email'] : '' ?>" required><br>

  <label>Product:</label>
  <input type="text" name="product" value="<?= $editUser ? $editUser['product'] : '' ?>" placeholder="Product" required><br>

  <label>Amount:</label>
  <input type="number" step="0.01" name="amount" value="<?= $editUser ? $editUser['amount'] : '' ?>" placeholder="Amount" required><br>

  <?php if (!empty($editUser)): ?>
    <button type="submit" name="update">Update</button>
    <a href="landing.php">Cancel</a>
  <?php else: ?>
    <button type="submit" name="add">Add</button>
  <?php endif; ?>
</form>

<hr>

<h3>User List (Joined Data)</h3>

<table border="1" cellpadding="10">
  <tr>
    <th>ID</th>
    <th>Name</th>
    <th>Email</th>
    <th>Product</th> 
    <th>Amount</th>  
    <th>Action</th>
  </tr>

  <?php foreach ($users as $user): ?>
  <tr>
    <td><?= $user['users_id'] ?></td>
    <td><?= $user['name'] ?></td>
    <td><?= $user['email'] ?></td>
    <td><?= $user['product'] ?></td> 
    <td><?= $user['amount'] ?></td>  
    <td>
      <a href="?edit=<?= $user['users_id'] ?>">Edit</a> | 
      <a href="?delete=<?= $user['users_id'] ?>" onclick="return confirm('Delete this user?')">Delete</a>
    </td>
  </tr>
  <?php endforeach; ?>
</table>
